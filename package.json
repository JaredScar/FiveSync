{
  "name": "fivesync",
  "version": "1.0.0",
  "description": "FiveM server artifact manager and auto-updater",
  "main": "out/main/index.js",
  "author": "FiveSync",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "lint": "eslint src --ext .js,.jsx",
    "lint:fix": "eslint src --ext .js,.jsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "axios": "^1.6.7",
    "electron-updater": "^6.8.3",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.2.3",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.1.3",
    "vitest": "^4.1.4",
    "zustand": "^4.5.1"
  },
  "build": {
    "appId": "com.fivesync.app",
    "productName": "FiveSync",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "out/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "your-github-username",
      "repo": "FiveSync"
    }
  }
}
